# ------------------------------------------------------------------------------
# 1. ENVIRONMENT & PATHS (Move to top for speed)
# ------------------------------------------------------------------------------
export HOMEBREW_PREFIX="/opt/homebrew"
export PYENV_ROOT="$HOME/.pyenv"
export PNPM_HOME="$HOME/Library/pnpm"
export ANDROID_HOME="$HOME/Library/Android/sdk"
export JAVA_HOME="/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home"

typeset -U path
path=(
  "$HOME/.local/bin"
  "$HOME/.bun/bin"
  "$HOME/.cargo/bin"
  "$HOME/.lmstudio/bin"
  "$HOME/.antigravity/antigravity/bin"
  "$HOME/.local/share/solana/install/active_release/bin"
  "$HOME/Library/Android/sdk/emulator"
  "$HOME/Library/Android/sdk/platform-tools"
  "$HOMEBREW_PREFIX/bin"
  "$HOMEBREW_PREFIX/sbin"
  "$HOMEBREW_PREFIX/opt/openjdk/bin"
  "$HOMEBREW_PREFIX/opt/mysql-client/bin"
  "$PYENV_ROOT/bin"
  "$PNPM_HOME"
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
  $path
)

fpath+=~/.zfunc

# Compiler Flags & 1Password
export LDFLAGS="-L$HOMEBREW_PREFIX/opt/mysql-client/lib"
export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/mysql-client/include"
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
export EDITOR='vim'
export BAT_THEME="tokyonight_night"

# ------------------------------------------------------------------------------
# 2. GREETING (Show before prompt)
# ------------------------------------------------------------------------------
if command -v figlet &> /dev/null; then
    figlet "It works on my machine." | lolcat
fi

# ------------------------------------------------------------------------------
# 3. ZINIT INSTALLER & CORE
# ------------------------------------------------------------------------------
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    command mkdir -p "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# ------------------------------------------------------------------------------
# 3. PROMPT (Starship) - Load this as fast as possible
# ------------------------------------------------------------------------------
zinit ice as"command" from"gh-r" atload'eval "$(starship init zsh)"'
zinit light starship/starship

# ------------------------------------------------------------------------------
# 4. PLUGINS & SNIPPETS (Turbo Mode - wait"0")
# ------------------------------------------------------------------------------
# Load annexes
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

# Deferred loading for non-critical components
zinit wait"0" lucid for \
    OMZ::lib/theme-and-appearance.zsh \
    OMZ::lib/completion.zsh \
    OMZ::lib/history.zsh \
    OMZ::lib/key-bindings.zsh \
    OMZ::lib/git.zsh \
    OMZ::plugins/git/git.plugin.zsh \
    OMZ::plugins/sudo/sudo.plugin.zsh

zinit ice wait"0" lucid atload"_zsh_autosuggest_start"
zinit light zsh-users/zsh-autosuggestions

zinit ice wait"0" lucid atinit"zpcompinit; zpcdreplay"
zinit light zsh-users/zsh-syntax-highlighting

zinit ice wait"0" lucid
zinit light zsh-users/zsh-completions

# ------------------------------------------------------------------------------
# 5. TOOLS INITIALIZATION (Deferred with Zinit Turbo)
# ------------------------------------------------------------------------------
zinit ice wait"0" lucid atload'eval "$(zoxide init zsh)"; alias cd="z"'
zinit light zdharma-continuum/null

zinit ice wait"0" lucid atload'eval "$(fnm env --use-on-cd --shell zsh)"'
zinit light zdharma-continuum/null

zinit ice wait"0" lucid atload'source <(fzf --zsh)'
zinit light zdharma-continuum/null

zinit ice wait"0" lucid atload'eval "$(pyenv init - zsh)"'
zinit light zdharma-continuum/null

# ------------------------------------------------------------------------------
# 6. HISTORY & ALIASES
# ------------------------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory
setopt sharehistory

# FZF Config
export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

# Aliases
alias ls="eza"
alias l="eza -l --icons --git -a --ignore-glob '.git|.DS_Store'"
alias lt="eza --tree --level=2 --long --icons --git --ignore-glob '.git|.DS_Store'"
alias ltree="eza --tree --level=2 --icons --git --ignore-glob '.git|.DS_Store'"
alias gca='gemini "Review my staged changes, suggest a one-line Conventional Commit message, and wait for my OK before committing."'

# ------------------------------------------------------------------------------
# 8. LOCAL OVERRIDES (Not tracked in chezmoi/git)
# ------------------------------------------------------------------------------
if [[ -f "$HOME/.zshrc_local" ]]; then
    source "$HOME/.zshrc_local"
fi
