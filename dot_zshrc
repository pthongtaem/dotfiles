# ------------------------------------------------------------------------------
# 1. OPTIMIZED HOMEBREW & ZSH SPEEDUP
# ------------------------------------------------------------------------------
# Set static Homebrew prefix for faster loading (Hardcoded for Apple Silicon)
export HOMEBREW_PREFIX="/opt/homebrew"

# Speed up compinit by checking cache (Run compinit once a day)
autoload -Uz compinit
for dump in "${ZDOTDIR:-$HOME}/.zcompdump"(N.mh+24); do
  compinit
done
compinit -C

# ------------------------------------------------------------------------------
# 2. ENVIRONMENT VARIABLES & PATHS
# ------------------------------------------------------------------------------
# Consolidate PATH for easier management
typeset -U path # Prevent duplicate path entries
path=(
  "$HOME/.local/bin"
  "$HOME/.bun/bin"
  "$HOME/.cargo/bin"
  "$HOME/.lmstudio/bin"
  "$HOME/.antigravity/antigravity/bin"
  "$HOME/.local/share/solana/install/active_release/bin"
  "$HOME/Library/Android/sdk/emulator"
  "$HOME/Library/Android/sdk/platform-tools"
  "$HOMEBREW_PREFIX/bin"
  "$HOMEBREW_PREFIX/sbin"
  "$HOMEBREW_PREFIX/opt/openjdk/bin"
  "$HOMEBREW_PREFIX/opt/mysql-client/bin"
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
  $path
)

# Android & Java
export ANDROID_HOME="$HOME/Library/Android/sdk"
export JAVA_HOME="/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home"

# Compiler Flags & 1Password
export LDFLAGS="-L$HOMEBREW_PREFIX/opt/mysql-client/lib"
export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/mysql-client/include"
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
export EDITOR='vim'
export BAT_THEME="tokyonight_night"

# ------------------------------------------------------------------------------
# 3. HISTORY CONFIGURATION
# ------------------------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS       # Do not save consecutive duplicates
setopt HIST_IGNORE_ALL_DUPS   # Remove older duplicate commands when a new one is typed
setopt HIST_REDUCE_BLANKS     # Remove excess blanks
setopt SHARE_HISTORY          # Share history across terminal sessions immediately
setopt INC_APPEND_HISTORY     # Save commands as soon as they are executed

# ------------------------------------------------------------------------------
# 4. ANTIDOTE PLUGIN MANAGER
# ------------------------------------------------------------------------------
fpath=($HOME/.docker/completions $fpath)
source "$HOMEBREW_PREFIX/opt/antidote/share/antidote/antidote.zsh"
antidote load

# ------------------------------------------------------------------------------
# 5. INTERACTIVE TOOL INITS
# ------------------------------------------------------------------------------
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
alias cd="z"
eval "$(fnm env --use-on-cd --shell zsh)"

# ------------------------------------------------------------------------------
# 6. FZF CONFIGURATION
# ------------------------------------------------------------------------------
source <(fzf --zsh)
export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

# ------------------------------------------------------------------------------
# 7. ALIASES
# ------------------------------------------------------------------------------
# Eza & Gemini Aliases
alias ls="eza"
alias l="eza -l --icons --git -a --ignore-glob '.git|.DS_Store'"
alias lt="eza --tree --level=2 --long --icons --git --ignore-glob '.git|.DS_Store'"
alias ltree="eza --tree --level=2 --icons --git --ignore-glob '.git|.DS_Store'"
alias gca='gemini "Review my staged changes, suggest a one-line Conventional Commit message, and wait for my OK before committing."'

# Git Aliases
alias gst='git status'
alias ga='git add'
alias gc='git commit -v'
alias gp='git push'
alias ggpush='git push'
alias gl='git pull'
alias ggpull='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'

# ------------------------------------------------------------------------------
# FINAL GREETING
# ------------------------------------------------------------------------------
if [[ -n $(command -v figlet) && -n $(command -v lolcat) ]]; then
  figlet "It works on my machine." | lolcat
fi
